import java.util.*;

public class DescendingTreeSet {
    public static void main(String[] args) {
        TreeSet<Integer> set = new TreeSet<>();

        set.add(10);
        set.add(40);
        set.add(20);
        set.add(30);

        System.out.println("Ascending : " + set);
        System.out.println("Descending: " + set.descendingSet());
    }
}